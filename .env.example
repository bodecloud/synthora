# --- Platform ---
SYNTHORA_DATABASE_URL=postgresql+asyncpg://synthora:synthora@localhost:5432/synthora
SYNTHORA_REDIS_URL=redis://localhost:6379/0
SYNTHORA_AUTH_MODE=none            # none | session
SYNTHORA_SECRET_KEY=change-me      # REQUIRED non-default when AUTH_MODE=session
SYNTHORA_CHECKPOINT_BACKEND=postgres # memory | postgres (compose default: postgres)
SYNTHORA_CHECKPOINT_URL=           # defaults to SYNTHORA_DATABASE_URL (psycopg form)
SYNTHORA_MCP_ALLOWLIST=            # comma-separated hosts for remote MCP (SSRF guard)
SYNTHORA_MCP_DNS_REBINDING_PROTECTION=0  # 1 to enable Host/Origin checks on /mcp
SYNTHORA_MCP_ALLOWED_HOSTS=        # e.g. localhost:*,api.example.com:*
SYNTHORA_MCP_ALLOWED_ORIGINS=      # e.g. https://app.example.com
SYNTHORA_NEWS_POLL=1               # worker background news poller
SYNTHORA_NEWS_POLL_INTERVAL=300
SYNTHORA_USE_ALEMBIC=1             # run alembic upgrade head on postgres boot
SYNTHORA_EMBEDDINGS=hash           # hash | openai | ollama (compose default: hash)
SYNTHORA_API_PORT=8000
SYNTHORA_WEB_PORT=3000

# --- Postgres (compose) ---
POSTGRES_USER=synthora
POSTGRES_PASSWORD=synthora
POSTGRES_DB=synthora

# --- LLM providers ---
OPENAI_API_KEY=
OPENAI_BASE_URL=                   # optional: OpenRouter / vLLM / LM Studio
OLLAMA_BASE_URL=http://localhost:11434

# --- Search ---
SEARXNG_URL=http://localhost:8080
SEARXNG_PORT=8080
TAVILY_API_KEY=
